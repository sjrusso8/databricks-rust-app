# Local dev config — copy to .env. The app reads standard PG* vars (or a single
# DATABASE_URL). PGPASSWORD is a Lakebase OAuth token (~1h) so export it fresh
# rather than storing it here — see the README for the one-liner.
PGHOST=REPLACE_WITH_ENDPOINT_HOST
PGPORT=5432
PGUSER=you@email.com
PGDATABASE=databricks_postgres
PGSSLMODE=require
# export PGPASSWORD=$(databricks postgres generate-database-credential \
#   projects/rust-api-app/branches/production/endpoints/primary -p fevm -o json | jq -r .token)
